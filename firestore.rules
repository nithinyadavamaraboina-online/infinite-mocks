rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ===============================================================
    // Collections
    // ===============================================================

    match /mocks/{mockId} {
      allow read, delete: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isOwner(resource.data.userId) && isOwner(request.resource.data.userId);
    }

    match /courses/{courseId} {
      allow read, delete: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isOwner(resource.data.userId) && isOwner(request.resource.data.userId);
    }

    match /search_stats/{examName} {
      allow read: if true;
      allow create, update: if isAuthenticated();
    }

    match /exam_cache/{examName} {
      allow read: if true;
      allow create, update: if isAuthenticated();
    }

    match /patterns/{patternId} {
      allow read: if true;
      allow create, update: if isAuthenticated();
    }

    match /questions/{questionId} {
      allow read: if true;
      allow create, update: if isAuthenticated() &&
                               request.resource.data.keys().hasAll(['question', 'options', 'correctAnswer', 'explanation', 'section', 'difficulty', 'examName']) &&
                               request.resource.data.question is string &&
                               request.resource.data.options is list &&
                               request.resource.data.correctAnswer is string &&
                               request.resource.data.explanation is string &&
                               request.resource.data.section is string &&
                               request.resource.data.difficulty is string &&
                               request.resource.data.examName is string;
    }

    match /user_logs/{logId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isOwner(resource.data.userId) && isOwner(request.resource.data.userId);
    }

    match /user_exam_history/{historyId} {
      allow read, delete: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isOwner(resource.data.userId) && isOwner(request.resource.data.userId);
    }

    match /user_capabilities/{userId} {
      allow read, delete: if isOwner(userId);
      allow create: if isOwner(userId) && isOwner(request.resource.data.userId);
      allow update: if isOwner(userId) && isOwner(request.resource.data.userId);
    }
  }
}
